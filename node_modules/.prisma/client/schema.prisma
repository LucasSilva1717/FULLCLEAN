datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model BudgetRequest {
  id           String   @id @default(uuid())
  name         String
  phone        String
  email        String
  state        String
  neighborhood String
  zipCode      String   @map("zip_code")
  serviceType  String   @map("service_type")
  message      String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("budget_requests")
}
